generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String          @unique
  password      String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  inboxSettings InboxSetting[]
  shipments     Shipment[]     // 🔄 Relational Link: Connects users directly to their tracking streams
}

model InboxSetting {
  id               String   @id @default(uuid())
  userId           String
  emailAddress     String   @unique // Prevents multiple profiles claiming the same exact inbox
  imapHost         String
  encryptedPass    String   // Stores our secure AES-256 encrypted string
  trackingSentence String   @default("Track all my incoming updates, alerts, and transaction statuses.") // 🔄 Day 16 Upgrade: AI Natural Language Goal Statement
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Shipment {
  id              String         @id @default(uuid())
  userId          String        
  trackingNumber  String
  origin          String
  destination     String
  status          ShipmentStatus @default(ON_TIME)
  currentLocation String?
  emailUrl        String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  aiAnalysis      AIAnalysis?
  rawLogs         RawLog[]
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

 
  @@unique([userId, trackingNumber])
}

model RawLog {
  id         String    @id @default(uuid())
  shipmentId String?
  rawText    String
  processed  Boolean   @default(false)
  receivedAt DateTime  @default(now())
  shipment   Shipment? @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
}

model AIAnalysis {
  id              String   @id @default(uuid())
  shipmentId      String   @unique
  nlpLabel        String
  confidenceScore Float
  severityLevel   Int
  summary         String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  shipment        Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
}

enum ShipmentStatus {
  ON_TIME
  DELAYED
  CRITICAL
}